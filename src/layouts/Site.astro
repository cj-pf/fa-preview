---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/tokens.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'Fiduciary Alliance — an advisor-owned network of independent RIAs.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;500;600;700&family=Mulish:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body>
    <Header transition:persist />
    <slot />
    <Footer />
    <script>
      // Connect to Sanity's Presentation (preview) pane so editors can navigate
      // the site from the Studio. Only runs inside an iframe (the preview pane),
      // and the (heavy) library is dynamically imported so normal visitors never
      // download it.
      if (window.self !== window.top) {
        import('@sanity/visual-editing').then(({enableVisualEditing}) => enableVisualEditing());
      }
    </script>
  </body>
</html>
