---
import Site from '../layouts/Site.astro';
import { url } from '../utils/url';

const platform = [
  { num: '01', title: 'COMPLIANCE, HANDLED.', body: 'SEC filings, ADV updates, marketing reviews — without the burden landing on you.' },
  { num: '02', title: 'A BEST-IN-CLASS STACK.', body: 'Schwab, Fidelity, Orion, eMoney, RightCapital — and the freedom to pick.' },
  { num: '03', title: 'INVESTMENT FREEDOM.', body: 'Use our portfolios. Or yours. No mandated models. Ever.' },
  { num: '04', title: 'OPERATIONS SUPPORT.', body: 'Onboarding, account opening, money movement — done for you.' },
  { num: '05', title: 'A PEER NETWORK.', body: 'Advisors who’ve been where you are. On the line when you need them.' },
  { num: '06', title: 'MARKETING THAT FITS YOU.', body: 'Brand, web, content — calibrated to your market, not stamped on top.' },
];

const techStack = [
  { category: 'Custodians', items: ['SCHWAB', 'FIDELITY'] },
  { category: 'Portfolio & Trading', items: ['ORION', 'TAMARAC'] },
  { category: 'Planning', items: ['EMONEY', 'RIGHTCAPITAL'] },
  { category: 'CRM & Compliance', items: ['WEALTHBOX', 'RIA IN A BOX'] },
];
---

<Site title="Why Fiduciary Alliance — Built by advisors, owned by advisors.">

  <section class="hero hero-why">
    <div class="container grid">
      <div>
        <p class="eyebrow">Why Fiduciary Alliance</p>
        <h1>BUILT BY ADVISORS.<br/>OWNED BY ADVISORS.<br/>BUILT TO STAY THAT WAY.</h1>
        <div class="actions">
          <a class="btn btn-primary" href={url('/contact')}>See if you&rsquo;re a fit <span class="arrow">→</span></a>
        </div>
      </div>
      <div class="hero-aside">
        <p class="lede">Most advisor networks exist to be sold. Fiduciary Alliance exists to grow.</p>
      </div>
    </div>
  </section>

  <section class="surface-elev section-sm">
    <div class="container">
      <div class="section-head" style="max-width:880px;">
        <p class="eyebrow">The model</p>
        <h2>A FEDERATION OF INDEPENDENT FIRMS — NOT A HOLDING COMPANY.</h2>
        <p style="margin-top:1.25rem;">Each member firm keeps its name, its clients, and its ownership. The alliance provides the compliance, technology, and peer infrastructure that&rsquo;s expensive to build alone.</p>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">What you get</p>
        <h2>THE PLATFORM.</h2>
      </div>
      <div class="outcomes">
        {platform.map(o => (
          <div class="outcome">
            <div class="num">{o.num}</div>
            <h3>{o.title}</h3>
            <p>{o.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="surface-elev">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Tech stack — by category</p>
        <h2>BEST-IN-CLASS. GROUPED, NOT DUMPED.</h2>
      </div>
      <div style="display:grid;gap:0;">
        {techStack.map((group, idx) => (
          <div style={`display:grid;grid-template-columns:220px 1fr;gap:2rem;padding:1.5rem 0;border-top:1px solid var(--line);${idx === techStack.length - 1 ? 'border-bottom:1px solid var(--line);' : ''}align-items:center;`}>
            <div style="font-family:var(--display);font-size:0.8125rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--ink-mute);font-weight:600;">{group.category}</div>
            <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
              {group.items.map(item => (
                <span class="firm-tile" style="min-width:140px;">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-strip">
    <div class="container">
      <div class="cta-row">
        <h2>READY TO SEE IF THERE&rsquo;S A FIT?</h2>
        <div class="actions">
          <a class="btn btn-primary" href={url('/contact')}>See if you&rsquo;re a fit <span class="arrow">→</span></a>
        </div>
      </div>
    </div>
  </section>

</Site>
