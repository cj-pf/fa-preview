---
import Site from '../layouts/Site.astro';
import { sanityClient } from '../lib/sanity';

const firms = await sanityClient.fetch(`*[_type == "memberFirm"] | order(name asc) {
  _id,
  name,
  streetAddress,
  city,
  state,
  zipCode,
  phone,
  numberOfOffices,
  shortDescription,
  website,
  "logoUrl": logo.asset->url
}`);
---

<Site title="Member Firms — Fiduciary Alliance">

  <section style="padding-top:clamp(8rem,15vh,12rem);padding-bottom:var(--section);">
    <div class="container">
      <h1 style="margin-bottom:1.5rem;">24 FIRMS. 10 STATES.</h1>

      <div style="margin-top:5rem;display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:1rem;">
        {firms.map((firm) => (
          <article style="position:relative;border:1px solid rgba(255,255,255,0.12);padding:1.25rem 1.5rem 1.75rem;border-radius:4px;min-height:11rem;">
            <h2 style="margin:0 0 0.5rem;font-size:1.125rem;letter-spacing:0.04em;line-height:1.3;padding-right:5rem;">{firm.name}</h2>
            {firm.streetAddress && <p style="margin:0;opacity:0.65;font-size:0.875rem;line-height:1.4;">{firm.streetAddress}</p>}
            <p style="margin:0;opacity:0.65;font-size:0.875rem;line-height:1.4;">{firm.city}, {firm.state}{firm.zipCode ? ` ${firm.zipCode}` : ''}</p>
            {firm.phone && <p style="margin:0.4rem 0 0;opacity:0.65;font-size:0.875rem;"><a href={`tel:${firm.phone}`} style="color:inherit;text-decoration:none;">{firm.phone}</a></p>}
            {firm.shortDescription && <p style="margin:0.75rem 0 0;font-size:0.9rem;line-height:1.5;">{firm.shortDescription}</p>}
            {firm.website && <p style="margin:0.75rem 0 0;font-size:0.875rem;"><a href={firm.website} target="_blank" rel="noopener" style="color:inherit;">Visit website →</a></p>}
            {firm.logoUrl && <img src={firm.logoUrl} alt={`${firm.name} logo`} style="position:absolute;bottom:1rem;right:1rem;max-width:80px;max-height:48px;object-fit:contain;opacity:0.9;" />}
          </article>
        ))}
      </div>
    </div>
  </section>

</Site>
