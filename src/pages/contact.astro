---
import Site from '../layouts/Site.astro';
import { getSiteSettings, phoneToTel } from '../lib/sanity';
const settings = await getSiteSettings();
---

<Site title="Contact — Fiduciary Alliance">

  <section style="padding-top:clamp(8rem,15vh,12rem);padding-bottom:var(--section);">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1 style="margin-bottom:1.5rem;">SEE IF YOU&rsquo;RE A FIT.</h1>
      <p class="lede" style="margin-bottom:3rem;">A short qualifier form to start a confidential conversation. Coming soon.</p>

      <div class="grid-2" style="align-items:start;">
        <div>
          <h3 style="margin-bottom:1rem;">In the meantime</h3>
          <p style="margin-bottom:0.5rem;"><a href={`tel:${phoneToTel(settings.phone)}`} class="btn-link">{settings.phone}</a></p>
          <p style="margin-bottom:0.5rem;"><a href={`mailto:${settings.email}`} class="btn-link">{settings.email}</a></p>
          <p style="margin-top:2rem;color:var(--ink-mute);font-size:0.9375rem;">RIA owners — partnership inquiries route to Brian directly: <a href="mailto:partnership@fiduciaryalliance.org" style="color:var(--brand-teal-bright);">partnership@fiduciaryalliance.org</a>.</p>
        </div>
        <div>
          <h3 style="margin-bottom:1rem;">Where we are</h3>
          <p>{settings.address}</p>
        </div>
      </div>
    </div>
  </section>

</Site>
