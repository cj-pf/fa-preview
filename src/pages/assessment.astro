---
import Site from '../layouts/Site.astro';
import { sanityClient } from '../lib/sanity';

const DEFAULTS = {
  pageTitle: 'Health Assessment — Fiduciary Alliance',
  iframeUrl: 'https://claude-assessment-sigma.vercel.app/embed',
};

const page = await sanityClient.fetch(
  `*[_type == "assessmentPage"][0]{ pageTitle, iframeUrl }`,
);

const pageTitle = page?.pageTitle || DEFAULTS.pageTitle;
const iframeUrl = page?.iframeUrl || DEFAULTS.iframeUrl;

// Fallback height used until the embedded app posts its actual content height.
// Sized generously so the tallest single step still fits without an inner scroll.
// The embedded app renders step 1 at ~930px tall; buffer to 1000 so nothing
// gets clipped. Overridden the moment the app posts a real height via
// `postMessage({type:'assessment:resize', height})`.
const FALLBACK_HEIGHT_PX = 1000;
---

<Site title={pageTitle}>
  <section class="assessment-shell">
    <iframe
      class="assessment-frame"
      src={iframeUrl}
      title="Practice Health Assessment"
      loading="lazy"
      scrolling="no"
      allow="clipboard-write"
      style={`height: ${FALLBACK_HEIGHT_PX}px;`}
    ></iframe>
  </section>
</Site>

<style>
  /* Continuous white surface below the fixed 84px header — no dark band, no gap.
     The outer page owns the scroll; the iframe stretches to whatever height the
     embedded app reports (with a generous fallback below). */
  .assessment-shell {
    padding: 84px 0 0;
    width: 100%;
    background: #ffffff;
    display: block;
  }
  .assessment-frame {
    display: block;
    width: 100%;
    border: 0;
    background: #ffffff;
  }
</style>

<script>
  // Accept height updates from the embedded assessment app so the outer page
  // owns the scroll (no inner iframe scrollbar). The app just needs to post:
  //   window.parent.postMessage({type:'assessment:resize', height:N}, '*')
  // We also accept a couple of common alternates (iframe-resizer, generic).
  function initAssessmentAutoResize() {
    const frame = document.querySelector<HTMLIFrameElement>('.assessment-frame');
    if (!frame) return;
    const EXPECTED_ORIGIN = new URL(frame.src).origin;
    const handler = (e: MessageEvent) => {
      if (e.origin !== EXPECTED_ORIGIN) return;
      const data: any = e.data;
      if (!data) return;
      let h: number | undefined;
      if (typeof data === 'object') {
        if (data.type === 'assessment:resize' && typeof data.height === 'number') h = data.height;
        else if (data.type === 'resize' && typeof data.height === 'number') h = data.height;
        else if (typeof data.height === 'number') h = data.height;
      } else if (typeof data === 'string' && data.startsWith('height:')) {
        h = parseInt(data.slice(7), 10);
      }
      if (h && h > 200 && h < 10000) frame.style.height = h + 'px';
    };
    window.addEventListener('message', handler);
  }
  initAssessmentAutoResize();
  document.addEventListener('astro:page-load', initAssessmentAutoResize);
</script>
