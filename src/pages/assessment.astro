---
import Site from '../layouts/Site.astro';
import { sanityClient } from '../lib/sanity';

const DEFAULTS = {
  pageTitle: 'Health Assessment — Fiduciary Alliance',
  iframeUrl: 'https://claude-assessment-sigma.vercel.app/embed',
};

const page = await sanityClient.fetch(
  `*[_type == "assessmentPage"][0]{ pageTitle, iframeUrl }`,
);

const pageTitle = page?.pageTitle || DEFAULTS.pageTitle;
const iframeUrl = page?.iframeUrl || DEFAULTS.iframeUrl;
---

<Site title={pageTitle}>
  <section class="assessment-shell">
    <iframe
      class="assessment-frame"
      src={iframeUrl}
      title="Practice Health Assessment"
      loading="lazy"
      allow="clipboard-write"
    ></iframe>
  </section>
</Site>

<style>
  /* Fill the viewport below the fixed 84px header so the survey feels like a dedicated app.
     Footer sits below, reachable by scrolling past the iframe. */
  .assessment-shell {
    height: calc(100vh - 84px);
    width: 100%;
    background: #0a1a24;
  }
  .assessment-frame {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
