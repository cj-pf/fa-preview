---
import Site from '../layouts/Site.astro';
import AISection from '../components/AISection.astro';
import { url } from '../utils/url';
import { sanityClient, getSiteSettings } from '../lib/sanity';
import { feature } from 'topojson-client';
import { geoAlbersUsa, geoPath } from 'd3-geo';
import usTopologyRaw from '../data/us-states-10m.json';
import { FIPS_TO_ABBR } from '../data/firmCityCoords';
import { geocodeFirm } from '../lib/geocode';

const settings = await getSiteSettings();

const home = await sanityClient.fetch(`*[_type == "homePage"][0]{
  heroHeadline,
  statAum
}`);

// Preserve the designed line break: a comma in the headline becomes a line break.
const heroHeadlineHtml = (home?.heroHeadline ?? 'YOUR GROWTH, OUR MISSION.').replace(/,\s*/g, ',<br/>');

const memberFirms = await sanityClient.fetch(`*[_type == "memberFirm" && defined(name)]{
  name,
  streetAddress,
  city,
  state,
  zipCode,
  numberOfOffices
} | order(name asc)`);

// Firm and state counts are derived from the published member firms so they
// stay in sync as firms are added / removed in Studio.
const firmCount = memberFirms.length;
const stateCount = new Set(
  memberFirms.map((f: any) => String(f.state || '').toUpperCase().trim()).filter(Boolean)
).size;

// Firms & States count up from a number; AUM is shown verbatim (it's a free-text field, e.g. "$1.8B").
const stats = [
  { to: firmCount,  decimals: 0, prefix: '', suffix: '', lbl: 'Member firms',      text: null as string | null },
  { to: stateCount, decimals: 0, prefix: '', suffix: '', lbl: 'States',            text: null as string | null },
  { to: 0,          decimals: 0, prefix: '', suffix: '', lbl: 'Assets under mgmt', text: (home?.statAum ?? '$1.8B') as string | null },
];

// "Our footprint": member firms grouped by state, most first. Offices = numberOfOffices (min 1 per firm).
const US_STATES: Record<string, string> = { AL:'Alabama', AK:'Alaska', AZ:'Arizona', AR:'Arkansas', CA:'California', CO:'Colorado', CT:'Connecticut', DE:'Delaware', FL:'Florida', GA:'Georgia', HI:'Hawaii', ID:'Idaho', IL:'Illinois', IN:'Indiana', IA:'Iowa', KS:'Kansas', KY:'Kentucky', LA:'Louisiana', ME:'Maine', MD:'Maryland', MA:'Massachusetts', MI:'Michigan', MN:'Minnesota', MS:'Mississippi', MO:'Missouri', MT:'Montana', NE:'Nebraska', NV:'Nevada', NH:'New Hampshire', NJ:'New Jersey', NM:'New Mexico', NY:'New York', NC:'North Carolina', ND:'North Dakota', OH:'Ohio', OK:'Oklahoma', OR:'Oregon', PA:'Pennsylvania', RI:'Rhode Island', SC:'South Carolina', SD:'South Dakota', TN:'Tennessee', TX:'Texas', UT:'Utah', VT:'Vermont', VA:'Virginia', WA:'Washington', WV:'West Virginia', WI:'Wisconsin', WY:'Wyoming', DC:'District of Columbia' };
const stateOffices: Record<string, number> = {};
for (const f of memberFirms) {
  if (!f.state) continue;
  const abbr = String(f.state).toUpperCase().trim();
  const offices = Number(f.numberOfOffices) > 0 ? Number(f.numberOfOffices) : 1;
  stateOffices[abbr] = (stateOffices[abbr] || 0) + offices;
}
const stateList = Object.entries(stateOffices)
  .map(([abbr, offices]) => ({ name: US_STATES[abbr] || abbr, offices }))
  .sort((a, b) => b.offices - a.offices || a.name.localeCompare(b.name))
  .slice(0, 7);

// --- Map projection (built once at build time) ----------------------------
const MAP_W = 975;
const MAP_H = 610;
const projection = geoAlbersUsa().scale(1300).translate([MAP_W / 2, MAP_H / 2]);
const pathGen = geoPath(projection as any);

type StateFeature = { id?: string; properties?: { name?: string } };
const usTopology = usTopologyRaw as any;
const statesCollection = feature(usTopology, usTopology.objects.states) as any;

const memberStateSet = new Set(memberFirms.map((f: any) => String(f.state || '').toUpperCase().trim()).filter(Boolean));

const statePaths = (statesCollection.features as StateFeature[]).map((f) => {
  const abbr = FIPS_TO_ABBR[String(f.id ?? '')] || '';
  return {
    d: pathGen(f as any) || '',
    isMember: memberStateSet.has(abbr),
    name: f.properties?.name || '',
  };
}).filter(s => s.d);

// Group firms by proximity (~14px on the projected map) so adjacent cities
// share one pin with a combined tooltip.
const PIN_BUCKET = 14;
type PinGroup = { x: number; y: number; firms: string[]; isHq: boolean };
const pinGroups = new Map<string, PinGroup>();

for (const firm of memberFirms) {
  const coords = await geocodeFirm(firm);
  if (!coords) continue;
  const projected = projection([coords[1], coords[0]] as [number, number]);
  if (!projected) continue;
  const [x, y] = projected;
  // HQ = Parallel Financial in Greenville, SC
  const isHq = String(firm.name).toUpperCase().trim() === 'PARALLEL FINANCIAL';
  const bucketKey = `${Math.round(x / PIN_BUCKET)}|${Math.round(y / PIN_BUCKET)}`;
  const existing = pinGroups.get(bucketKey);
  if (existing) {
    existing.firms.push(firm.name);
    if (isHq) existing.isHq = true;
  } else {
    pinGroups.set(bucketKey, { x, y, firms: [firm.name], isHq });
  }
}
const pins = Array.from(pinGroups.values());

const steps = [
  { num: '01', title: 'TALK', body: 'A short conversation to see if there’s a fit. Both directions.' },
  { num: '02', title: 'DILIGENCE', body: 'We learn your practice. You learn the alliance.' },
  { num: '03', title: 'PLAN', body: 'Custodian, compliance, comms, tech. Mapped out.' },
  { num: '04', title: 'LAUNCH', body: 'You go live with the alliance behind you.' },
];
---

<Site title="Fiduciary Alliance — Your growth, our mission.">

  <section class="hero hero-home">
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      aria-hidden="true"
    >
      <source src={url('/hero.mp4')} type="video/mp4" />
    </video>
    <div class="container grid">
      <div>
        <p class="eyebrow">Advisor-owned · No private equity</p>
        <h1 set:html={heroHeadlineHtml}></h1>
        <div class="actions">
          <a class="btn btn-primary" href={settings.calendlyUrl} target="_blank" rel="noopener">See If You&rsquo;re a Fit <span class="arrow">→</span></a>
          <a class="btn btn-ghost" href={url('/how-it-works')}>How it works</a>
        </div>
      </div>
      <div class="hero-aside">
        <p class="lede">A network of independent RIAs designed to grow.</p>
      </div>
    </div>
  </section>

  <section class="stats">
    <div class="container">
      <div class="row">
        {stats.map((s, i) => (
          <div class="stat anim-hidden" style={`--anim-delay: ${i * 100}ms`}>
            {s.text !== null ? (
              <div class="num">{s.text}</div>
            ) : (
              <div
                class="num"
                data-counter-to={s.to}
                data-counter-decimals={s.decimals}
                data-counter-prefix={s.prefix}
                data-counter-suffix={s.suffix}
              >{s.prefix}0{s.decimals > 0 ? '.' + '0'.repeat(s.decimals) : ''}{s.suffix}</div>
            )}
            <div class="lbl">{s.lbl}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-head anim-hidden">
        <p class="eyebrow">Choose your path</p>
        <h2>TWO WAYS IN.<br/>ONE ALLIANCE BEHIND YOU.</h2>
      </div>
      <div class="grid-2">
        <a class="persona-card anim-hidden" style="--anim-delay: 100ms" href={url('/why-fa/breakaway')}>
          <span class="tag">For IARs &amp; RRs</span>
          <h3>BREAK AWAY.<br/>WITHOUT STARTING OVER.</h3>
          <p>A turnkey platform — compliance, ops, tech, peers — so you can go independent without rebuilding from scratch.</p>
          <span class="more">For advisors <span class="arrow">→</span></span>
        </a>
        <a class="persona-card anim-hidden" style="--anim-delay: 200ms" href={url('/why-fa/ria-owners')}>
          <span class="tag">For RIA owners</span>
          <h3>KEEP YOUR FIRM.<br/>GAIN LEVERAGE.</h3>
          <p>A true partnership for independent RIAs. Not a tuck-in. Not an acquisition. Keep what you built.</p>
          <span class="more">For RIA owners <span class="arrow">→</span></span>
        </a>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-head anim-hidden" style="max-width:840px;">
        <p class="eyebrow">What we are. What we&rsquo;re not.</p>
        <h2>AN ALLIANCE — NOT A ROLLUP.</h2>
      </div>
      <div class="contrast">
        <div class="we-are anim-hidden" data-anim-from="left">
          <h4>We are</h4>
          <ul>
            <li>ADVISOR-OWNED</li>
            <li>FIDUCIARY-FIRST</li>
            <li>LONG-TERM ORIENTED</li>
            <li>GROWTH-FOCUSED</li>
          </ul>
        </div>
        <div class="we-arent anim-hidden" data-anim-from="right">
          <h4>We&rsquo;re not</h4>
          <ul>
            <li>PE-BACKED</li>
            <li>A BUILD-TO-FLIP PLAY</li>
            <li>MANDATING MODELS</li>
            <li>REPLACING YOUR BRAND</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <AISection />

  <section>
    <div class="container">
      <div class="section-head anim-hidden">
        <p class="eyebrow">A national network</p>
        <h2>{firmCount} FIRMS. {stateCount} STATES.<br/>ONE ALLIANCE.</h2>
      </div>
      <div class="network-block anim-hidden" style="--anim-delay: 100ms">
        <div class="network-map">
          <svg class={`us-map us-map-v2`} viewBox={`0 0 ${MAP_W} ${MAP_H}`} xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Map of Fiduciary Alliance member firms across the United States">
            <g class="us-states">
              {statePaths.map(s => (
                <path class={`us-state${s.isMember ? ' us-state-fa' : ''}`} d={s.d} data-state={s.name} />
              ))}
            </g>
            <g class="pins">
              {pins.filter(p => !p.isHq).map(p => (
                <circle
                  class="pin"
                  cx={p.x.toFixed(1)}
                  cy={p.y.toFixed(1)}
                  r="6"
                  tabindex="0"
                  data-firms={p.firms.join(' · ')}
                />
              ))}
            </g>
            {pins.filter(p => p.isHq).map(p => (
              <g class="pin-hq" transform={`translate(${p.x.toFixed(1)}, ${p.y.toFixed(1)})`}>
                <circle class="pin-hq-core" r="11" tabindex="0" data-firms={p.firms.join(' · ')} />
                <text class="pin-hq-label" y="3.5" text-anchor="middle">HQ</text>
              </g>
            ))}
          </svg>
          <div class="map-tooltip" role="tooltip" aria-hidden="true"></div>

        </div>

        <aside class="network-list">
          <span class="label">Our footprint</span>
          <ul class="state-list">
            {stateList.map(s => (
              <li>
                <span class="state-name">{s.name}</span>
                <span class="state-meta"><strong>{s.offices}</strong>{s.offices === 1 ? 'office' : 'offices'}</span>
              </li>
            ))}
          </ul>
          <a class="btn-link more" href={url('/firms')}>Explore member firms →</a>
        </aside>
      </div>
    </div>
  </section>

  <section class="surface-elev">
    <div class="container">
      <div class="section-head anim-hidden">
        <p class="eyebrow">How a partnership works</p>
        <h2>FOUR STEPS. NO SURPRISES.</h2>
      </div>
      <div class="steps">
        {steps.map((s, i) => (
          <div class="step anim-hidden" style={`--anim-delay: ${i * 100}ms`}>
            <div class="num">{s.num}</div>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="quote anim-hidden">
        <div class="mark">&ldquo;</div>
        <div class="text">We joined the alliance and still own our firm. That sentence doesn&rsquo;t exist anywhere else in this industry.</div>
        <div class="attrib">
          <div class="avatar"></div>
          <div class="who">
            <div class="name">Member firm principal</div>
            <div class="firm">Quote placeholder · TBD</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-strip">
    <div class="container">
      <div class="cta-row">
        <h2 class="anim-hidden">CURIOUS WHAT THIS COULD LOOK LIKE FOR YOU?</h2>
        <div class="actions anim-hidden" style="--anim-delay: 120ms">
          <a class="btn btn-primary" href={settings.calendlyUrl} target="_blank" rel="noopener">See If You&rsquo;re a Fit <span class="arrow">→</span></a>
          <a class="btn btn-ghost" href={url('/firms')}>Explore firms</a>
        </div>
      </div>
    </div>
  </section>

</Site>

<script>
  function setupHomeAnimations() {
    if (!('IntersectionObserver' in window)) {
      document.querySelectorAll('.anim-hidden').forEach(el => el.classList.add('anim-visible'));
      return;
    }

    const animObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        animObserver.unobserve(el);
        el.classList.add('anim-visible');
        const cleanup = () => el.classList.remove('anim-hidden', 'anim-visible');
        el.addEventListener('transitionend', cleanup, { once: true });
        window.setTimeout(cleanup, 1800);
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

    // Above-the-fold elements: reveal immediately (no entry animation) to avoid a flash.
    // Below-the-fold elements: observe and animate as they scroll in.
    const vh = window.innerHeight;
    document.querySelectorAll<HTMLElement>('.anim-hidden').forEach(el => {
      const rect = el.getBoundingClientRect();
      const inView = rect.top < vh && rect.bottom > 0;
      if (inView) {
        el.classList.remove('anim-hidden');
      } else {
        animObserver.observe(el);
      }
    });

    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        counterObserver.unobserve(el);
        animateCounter(el);
      });
    }, { threshold: 0.3 });

    document.querySelectorAll<HTMLElement>('[data-counter-to]').forEach(el => counterObserver.observe(el));
  }

  function animateCounter(el: HTMLElement) {
    const target = parseFloat(el.dataset.counterTo || '0');
    const decimals = parseInt(el.dataset.counterDecimals || '0', 10);
    const prefix = el.dataset.counterPrefix || '';
    const suffix = el.dataset.counterSuffix || '';
    const duration = 1000;
    const startTime = performance.now();
    const step = (now: number) => {
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const value = target * eased;
      el.textContent = `${prefix}${value.toFixed(decimals)}${suffix}`;
      if (progress < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  }

  function setupMapTooltip() {
    const tooltip = document.querySelector<HTMLElement>('.map-tooltip');
    if (!tooltip || tooltip.dataset.ready === '1') return;
    tooltip.dataset.ready = '1';

    const show = (e: Event) => {
      const el = e.currentTarget as SVGElement;
      const firms = el.getAttribute('data-firms');
      if (!firms) return;
      tooltip.textContent = firms;
      const rect = (el as unknown as SVGGraphicsElement).getBoundingClientRect();
      tooltip.style.left = `${rect.left + rect.width / 2}px`;
      tooltip.style.top = `${rect.top}px`;
      tooltip.classList.add('is-visible');
      tooltip.setAttribute('aria-hidden', 'false');
    };
    const hide = () => {
      tooltip.classList.remove('is-visible');
      tooltip.setAttribute('aria-hidden', 'true');
    };

    document.querySelectorAll<SVGElement>('.us-map [data-firms]').forEach((el) => {
      el.addEventListener('mouseenter', show);
      el.addEventListener('mouseleave', hide);
      el.addEventListener('focus', show);
      el.addEventListener('blur', hide);
    });
  }

  function setupHeroVideoFallback() {
    const video = document.querySelector<HTMLVideoElement>('.hero-video');
    const hero = document.querySelector<HTMLElement>('.hero-home');
    if (!video || !hero) return;
    const showPhoto = () => hero.classList.add('hero--video-failed');
    video.addEventListener('error', showPhoto);
    const source = video.querySelector('source');
    if (source) source.addEventListener('error', showPhoto);
  }

  setupHomeAnimations();
  setupMapTooltip();
  setupHeroVideoFallback();
  document.addEventListener('astro:page-load', () => {
    setupHomeAnimations();
    setupMapTooltip();
    setupHeroVideoFallback();
  });
</script>
