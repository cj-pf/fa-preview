---
import Logo from './Logo.astro';
import { url } from '../utils/url';
import { getSiteSettings, phoneToTel } from '../lib/sanity';
const settings = await getSiteSettings();
const currentPath = Astro.url.pathname;
type NavChild = { href: string; label: string; external?: boolean };
type NavItem = { href?: string; label: string; external?: boolean; children?: NavChild[] };
const nav: NavItem[] = [
  { href: '/', label: 'Home' },
  {
    label: 'Why FA',
    children: [
      { href: '/why-fa/breakaway', label: 'Breakaway' },
      { href: '/why-fa/ria-owners', label: 'RIA Owners' },
    ],
  },
  { href: '/firms', label: 'Firms' },
  { href: '/team', label: 'Team' },
  { href: '/insights', label: 'Insights' },
];
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---
<header class="site-header">
  <div class="container row">
    <Logo />
    <nav class="nav">
      {nav.map(item => (
        item.children ? (
          <div class="nav-item has-dropdown">
            <span class="nav-trigger" aria-current={item.children.some(c => isActive(c.href)) ? 'page' : undefined}>
              <span class="nav-label">{item.label}</span>
              <button
                type="button"
                class="nav-caret"
                aria-expanded="false"
                aria-haspopup="true"
                aria-label={`Open ${item.label} menu`}
              >
                <span class="caret" aria-hidden="true">▾</span>
              </button>
            </span>
            <ul class="dropdown" role="menu">
              {item.children.map(c => (
                <li role="none">
                  <a role="menuitem" href={url(c.href)} aria-current={isActive(c.href) ? 'page' : undefined}>{c.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ) : item.external ? (
          <a href={item.href!} target="_blank" rel="noopener">{item.label}</a>
        ) : (
          <a href={url(item.href!)} aria-current={isActive(item.href!) ? 'page' : undefined}>{item.label}</a>
        )
      ))}
    </nav>
    <div class="nav-right">
      <a class="phone" href={`tel:${phoneToTel(settings.phone)}`}>{settings.phone}</a>
      <a href={settings.calendlyUrl} target="_blank" rel="noopener" class="btn btn-primary">See If You&rsquo;re a Fit <span class="arrow">→</span></a>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector('.site-header');
  if (header) {
    const onScroll = () => {
      if (window.scrollY > 80) header.classList.add('scrolled');
      else header.classList.remove('scrolled');
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    const carets = header.querySelectorAll<HTMLButtonElement>('.nav-caret');
    const closeAll = (except?: HTMLButtonElement) => {
      carets.forEach(c => { if (c !== except) c.setAttribute('aria-expanded', 'false'); });
    };
    carets.forEach(caret => {
      caret.addEventListener('click', (e) => {
        e.stopPropagation();
        const open = caret.getAttribute('aria-expanded') === 'true';
        closeAll(caret);
        caret.setAttribute('aria-expanded', open ? 'false' : 'true');
      });
    });
    document.addEventListener('click', () => closeAll());
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeAll(); });
  }
</script>
