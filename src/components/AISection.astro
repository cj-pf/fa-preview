---
// AISection.astro — homepage "AI tools" section
// Content is hardcoded for now; we'll wire it to Sanity (homePage) in a later step.
const tools = ["Zocks", "Claude", "Black Diamond"];
const imageSrc = "/images/ai-tools.jpg";
---
<section class="ai-section" aria-labelledby="ai-heading">
  <!-- Mobile/tablet only: photo becomes a blurred parallax background -->
  <div class="ai-bg" aria-hidden="true">
    <img src={imageSrc} alt="" width="1086" height="1448" loading="lazy" data-ai-parallax />
  </div>
  <div class="container">
    <div class="ai-grid">
      <div class="ai-copy anim-hidden" data-anim-from="left">
        <p class="eyebrow ai-eyebrow">Technology that scales you</p>
        <h2 id="ai-heading">WE&rsquo;RE NOT AFRAID OF AI.<br/>WE PUT IT TO WORK FOR YOU.</h2>
        <p class="ai-sub">We put AI to work where it counts — meeting notes, follow-ups, research, and reporting. Less admin, more time to grow your practice.</p>

        <p class="ai-tools-label">The AI tools we run</p>
        <ul class="ai-tools">
          {tools.map((t) => <li class="ai-tool">{t}</li>)}
          <li class="ai-tool ai-tool--more">+ more</li>
        </ul>

        <p class="ai-effort"><strong>We don&rsquo;t just hand you tools — we train you to scale with them.</strong> Live walkthroughs, an advisor community, and ongoing coaching. Built for advisors ready to put in the effort and grow.</p>
      </div>

      <!-- Desktop only: photo sits in a bordered card in the right column -->
      <div class="ai-visual anim-hidden" data-anim-from="right" style="--anim-delay: 150ms">
        <img src={imageSrc} alt="Layered AI technology stack" width="1086" height="1448" loading="lazy" data-ai-parallax />
      </div>
    </div>
  </div>
</section>

<style>
  .ai-eyebrow { color: var(--brand-green-bright); }

  .ai-grid {
    display: grid;
    grid-template-columns: 1fr 0.82fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: stretch;
  }

  .ai-sub {
    margin-top: 1.5rem;
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 56ch;
  }

  .ai-tools-label {
    font-family: var(--display);
    font-size: 0.8125rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--brand-green-bright);
    font-weight: 600;
    margin: 2.5rem 0 0.875rem;
  }
  .ai-tools {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 0.625rem;
    flex-wrap: wrap;
  }
  .ai-tool {
    font-family: var(--display);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.625rem 1.125rem;
    border-radius: 4px;
    background: var(--surface);
    border: 1px solid var(--line);
    color: var(--ink);
  }
  .ai-tool--more { opacity: 0.6; font-weight: 400; }

  .ai-effort {
    margin: 2.5rem 0 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    max-width: 52ch;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--ink-soft);
  }
  .ai-effort strong { color: var(--ink); font-weight: 600; }

  /* ---------- Desktop (>820px): photo in a bordered card, no blurred bg ---------- */
  .ai-bg { display: none; }              /* blurred background is mobile/tablet only */
  .ai-section::after { display: none; }  /* scrim only exists over the blurred bg */

  .ai-visual {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
    min-height: 100%;
  }
  .ai-visual img {
    position: absolute;
    left: 0;
    top: -6%;
    width: 100%;
    height: 112%;
    object-fit: cover;
    display: block;
    /* Damp the shared parallax value so the desktop card keeps its subtle drift */
    transform: translateY(calc(var(--parallax-y, 0px) * 0.3));
    will-change: transform;
  }
  .ai-visual::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(180deg, transparent 58%, rgba(6, 21, 32, 0.4));
  }

  /* ---------- Mobile / tablet (<=820px): full-bleed blurred parallax photo ---------- */
  @media (max-width: 820px) {
    .ai-section {
      position: relative;
      isolation: isolate;
      overflow: hidden;
    }
    .ai-grid { grid-template-columns: 1fr; }
    .ai-copy { max-width: 620px; }
    .ai-visual { display: none; }        /* hide the desktop card */

    .ai-bg {
      display: block;
      position: absolute;
      inset: 0;
      z-index: -2;
      overflow: hidden;
      /* Populate the photo as the section scrolls into view */
      opacity: 0;
      transition: opacity 1s ease;
    }
    .ai-section.ai-in .ai-bg { opacity: 1; }
    .ai-bg img {
      position: absolute;
      /* Overscan on all sides: horizontal covers blur bleed / subpixel gaps,
         vertical gives room for the parallax travel */
      left: -6%;
      top: -30%;
      width: 112%;
      max-width: none;   /* override the global `img { max-width: 100% }` reset */
      height: 160%;
      object-fit: cover;
      filter: blur(2px);
      transform: translateY(var(--parallax-y, 0)) scale(1.04);
      /* No will-change here: promoting a blurred layer and clipping it with
         overflow:hidden renders a 1px seam at the section's bottom edge. */
    }
    /* Scrim keeps the light text readable AND blends the photo into the
       --bg sections above/below via the opaque top/bottom stops (no mask,
       which glitches on mobile GPUs when applied over a blurred layer). */
    .ai-section::after {
      display: block;
      content: "";
      position: absolute;
      inset: 0;
      z-index: -1;
      pointer-events: none;
      background:
        linear-gradient(180deg, #0A1A24 0%, #0A1A24 5%, rgba(10, 26, 36, 0) 35%, rgba(10, 26, 36, 0) 65%, #0A1A24 95%, #0A1A24 100%),
        linear-gradient(90deg, rgba(7, 21, 31, 0.92) 0%, rgba(7, 21, 31, 0.78) 55%, rgba(7, 21, 31, 0.6) 100%),
        radial-gradient(120% 120% at 15% 0%, rgba(7, 21, 31, 0.25), transparent 60%);
    }
  }

  @media (max-width: 640px) {
    .ai-bg img { filter: blur(1.5px); }
    .ai-section::after {
      background:
        linear-gradient(180deg, #0A1A24 0%, #0A1A24 5%, rgba(10, 26, 36, 0) 35%, rgba(10, 26, 36, 0) 65%, #0A1A24 95%, #0A1A24 100%),
        linear-gradient(90deg, rgba(7, 21, 31, 0.9) 0%, rgba(7, 21, 31, 0.82) 100%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-bg { opacity: 1 !important; transition: none; }
  }
</style>

<script>
  function initAIParallax(){
    const imgs = document.querySelectorAll<HTMLElement>('[data-ai-parallax]');
    const section = document.querySelector<HTMLElement>('.ai-section');
    if(!section) return;

    // Reveal: fade the photo in as the section scrolls into view.
    if(section.dataset.revealReady !== '1'){
      section.dataset.revealReady = '1';
      if('IntersectionObserver' in window){
        const io = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if(e.isIntersecting){ section.classList.add('ai-in'); io.disconnect(); }
          });
        }, { threshold: 0.12 });
        io.observe(section);
      } else {
        section.classList.add('ai-in');
      }
    }

    if(!imgs.length) return;
    if(window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    let ticking = false;
    function update(){
      const rect = section!.getBoundingClientRect();
      // Mobile/tablet parallax travel; the desktop card damps this in CSS.
      const shift = (rect.top + rect.height/2 - window.innerHeight/2) * -0.14;
      imgs.forEach(img => img.style.setProperty('--parallax-y', shift.toFixed(1) + 'px'));
      ticking = false;
    }
    function onScroll(){ if(!ticking){ requestAnimationFrame(update); ticking = true; } }
    window.addEventListener('scroll', onScroll, {passive:true});
    window.addEventListener('resize', onScroll);
    update();
  }
  document.addEventListener('astro:page-load', initAIParallax);
</script>
