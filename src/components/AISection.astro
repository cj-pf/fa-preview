---
// AISection.astro — homepage "AI tools" section
// Content is hardcoded for now; we'll wire it to Sanity (homePage) in a later step.
const tools = ["Zocks", "Claude", "Black Diamond"];
const imageSrc = "/images/ai-tools.jpg";
---
<section class="ai-section" aria-labelledby="ai-heading">
  <div class="ai-wrap">
    <div class="ai-grid">
      <div class="ai-copy">
        <p class="ai-eyebrow">Technology that scales you</p>
        <h2 id="ai-heading" class="ai-headline">We're not afraid of AI.<br><span class="ai-accent">We put it to work for you.</span></h2>
        <p class="ai-sub">We put AI to work where it counts — meeting notes, follow-ups, research, and reporting. Less admin, more time to grow your practice.</p>

        <p class="ai-tools-label">The AI tools we run</p>
        <ul class="ai-tools">
          {tools.map((t) => <li class="ai-tool">{t}</li>)}
          <li class="ai-tool ai-tool--more">+ more</li>
        </ul>

        <p class="ai-effort"><strong>We don't just hand you tools — we train you to scale with them.</strong> Live walkthroughs, an advisor community, and ongoing coaching. Built for advisors ready to put in the effort and grow.</p>
      </div>

      <div class="ai-visual">
        <img src={imageSrc} alt="Layered AI technology stack" width="1086" height="1448" loading="lazy" data-ai-parallax />
      </div>
    </div>
  </div>
</section>

<style>
  .ai-section{
    --ai-accent:#5FB6D9;
    --ai-accent-2:#7FE0CB;
    --ai-line:rgba(255,255,255,.10);
    --ai-line-strong:rgba(255,255,255,.18);
    --ai-glass:rgba(232,240,245,.08);
    position:relative;
    overflow:hidden;
    background:var(--bg);
    color:#EAF1F5;
    padding:clamp(72px,9vw,120px) 24px;
  }
  .ai-wrap{max-width:1120px;margin:0 auto;}
  .ai-grid{display:grid;grid-template-columns:1fr .82fr;gap:54px;align-items:center;}

  .ai-eyebrow{font-size:12px;letter-spacing:.24em;text-transform:uppercase;color:var(--ai-accent);font-weight:600;margin:0 0 20px;display:flex;align-items:center;gap:12px;}
  .ai-eyebrow::before{content:"";width:26px;height:1px;background:var(--ai-accent);opacity:.75;}

  .ai-headline{font-size:clamp(30px,4.4vw,52px);line-height:1.03;font-weight:800;letter-spacing:-.015em;margin:0 0 22px;}
  .ai-accent{background:linear-gradient(92deg,var(--ai-accent),var(--ai-accent-2));-webkit-background-clip:text;background-clip:text;color:transparent;}

  .ai-sub{font-size:17px;line-height:1.62;opacity:.9;max-width:560px;margin:0 0 36px;}

  .ai-tools-label{font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--ai-accent);font-weight:600;margin:0 0 14px;}
  .ai-tools{list-style:none;padding:0;margin:0;display:flex;gap:10px;flex-wrap:wrap;}
  .ai-tool{font-size:14.5px;font-weight:600;letter-spacing:.01em;padding:11px 18px;border-radius:999px;background:var(--ai-glass);border:1px solid var(--ai-line-strong);-webkit-backdrop-filter:blur(14px);backdrop-filter:blur(14px);}
  .ai-tool--more{font-weight:500;opacity:.65;}

  .ai-effort{margin:38px 0 0;padding-top:24px;border-top:1px solid var(--ai-line);max-width:48ch;font-size:15px;line-height:1.62;opacity:.82;}
  .ai-effort strong{font-weight:700;opacity:1;}

  .ai-visual{position:relative;border-radius:20px;overflow:hidden;border:1px solid var(--ai-line-strong);box-shadow:0 30px 80px rgba(0,0,0,.45);aspect-ratio:3/4;}
  .ai-visual img{position:absolute;left:0;top:-6%;width:100%;height:112%;object-fit:cover;display:block;will-change:transform;}
  .ai-visual::after{content:"";position:absolute;inset:0;pointer-events:none;background:linear-gradient(180deg,transparent 58%,rgba(8,17,25,.38));}

  @media (max-width:860px){
    .ai-grid{grid-template-columns:1fr;gap:40px;}
    .ai-visual{aspect-ratio:3/4;max-width:360px;width:100%;margin:0 auto;}
  }
  @media (prefers-reduced-motion:reduce){
    .ai-visual img{transform:none !important;top:0;height:100%;}
  }
</style>

<script>
  function initAIParallax(){
    const img = document.querySelector('[data-ai-parallax]');
    const section = document.querySelector('.ai-section');
    if(!img || !section) return;
    if(window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    let ticking = false;
    function update(){
      const rect = section.getBoundingClientRect();
      const shift = (rect.top + rect.height/2 - window.innerHeight/2) * -0.04;
      img.style.transform = 'translateY(' + shift.toFixed(1) + 'px)';
      ticking = false;
    }
    function onScroll(){ if(!ticking){ requestAnimationFrame(update); ticking = true; } }
    window.addEventListener('scroll', onScroll, {passive:true});
    window.addEventListener('resize', onScroll);
    update();
  }
  document.addEventListener('astro:page-load', initAIParallax);
</script>
