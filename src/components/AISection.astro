---
// AISection.astro — homepage "AI tools" section
// Content is hardcoded for now; we'll wire it to Sanity (homePage) in a later step.
const tools = ["Zocks", "Claude", "Black Diamond"];
const imageSrc = "/images/ai-tools.jpg";
---
<section class="ai-section" aria-labelledby="ai-heading">
  <div class="container">
    <div class="ai-grid">
      <div class="ai-copy">
        <p class="eyebrow ai-eyebrow">Technology that scales you</p>
        <h2 id="ai-heading">WE&rsquo;RE NOT AFRAID OF AI.<br/>WE PUT IT TO WORK FOR YOU.</h2>
        <p class="ai-sub">We put AI to work where it counts — meeting notes, follow-ups, research, and reporting. Less admin, more time to grow your practice.</p>

        <p class="ai-tools-label">The AI tools we run</p>
        <ul class="ai-tools">
          {tools.map((t) => <li class="ai-tool">{t}</li>)}
          <li class="ai-tool ai-tool--more">+ more</li>
        </ul>

        <p class="ai-effort"><strong>We don&rsquo;t just hand you tools — we train you to scale with them.</strong> Live walkthroughs, an advisor community, and ongoing coaching. Built for advisors ready to put in the effort and grow.</p>
      </div>

      <div class="ai-visual">
        <img src={imageSrc} alt="Layered AI technology stack" width="1086" height="1448" loading="lazy" data-ai-parallax />
      </div>
    </div>
  </div>
</section>

<style>
  .ai-eyebrow { color: var(--brand-green-bright); }

  .ai-grid {
    display: grid;
    grid-template-columns: 1fr 0.82fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: stretch;
  }

  .ai-sub {
    margin-top: 1.5rem;
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 56ch;
  }

  .ai-tools-label {
    font-family: var(--display);
    font-size: 0.8125rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--brand-green-bright);
    font-weight: 600;
    margin: 2.5rem 0 0.875rem;
  }
  .ai-tools {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 0.625rem;
    flex-wrap: wrap;
  }
  .ai-tool {
    font-family: var(--display);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.625rem 1.125rem;
    border-radius: 4px;
    background: var(--surface);
    border: 1px solid var(--line);
    color: var(--ink);
  }
  .ai-tool--more { opacity: 0.6; font-weight: 400; }

  .ai-effort {
    margin: 2.5rem 0 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    max-width: 52ch;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--ink-soft);
  }
  .ai-effort strong { color: var(--ink); font-weight: 600; }

  .ai-visual {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
    min-height: 100%;
  }
  .ai-visual img {
    position: absolute;
    left: 0;
    top: -6%;
    width: 100%;
    height: 112%;
    object-fit: cover;
    display: block;
    will-change: transform;
  }
  .ai-visual::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(180deg, transparent 58%, rgba(6, 21, 32, 0.4));
  }

  @media (max-width: 860px) {
    .ai-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .ai-visual { aspect-ratio: 3/4; max-width: 360px; width: 100%; margin: 0 auto; }
  }
  @media (prefers-reduced-motion: reduce) {
    .ai-visual img { transform: none !important; top: 0; height: 100%; }
  }
</style>

<script>
  function initAIParallax(){
    const img = document.querySelector('[data-ai-parallax]');
    const section = document.querySelector('.ai-section');
    if(!img || !section) return;
    if(window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    let ticking = false;
    function update(){
      const rect = section.getBoundingClientRect();
      const shift = (rect.top + rect.height/2 - window.innerHeight/2) * -0.04;
      img.style.transform = 'translateY(' + shift.toFixed(1) + 'px)';
      ticking = false;
    }
    function onScroll(){ if(!ticking){ requestAnimationFrame(update); ticking = true; } }
    window.addEventListener('scroll', onScroll, {passive:true});
    window.addEventListener('resize', onScroll);
    update();
  }
  document.addEventListener('astro:page-load', initAIParallax);
</script>
