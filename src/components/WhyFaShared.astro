---
import { getSiteSettings, sanityClient, urlFor } from '../lib/sanity';
const settings = await getSiteSettings();

// Bottom banner photo — shared across both Why FA pages, editable on the single
// "Why FA Page" document in Studio; falls back to the hardcoded --hero-home
// photo when left blank.
const whyFaPage = await sanityClient.fetch(`*[_type == "whyFaPage"][0]{
  ctaImage,
  ctaParallax
}`);
function imageUrl(image: any, w: number, h: number) {
  if (!image?.asset) return null;
  return urlFor(image).width(w).height(h).fit('crop').auto('format').quality(85).url();
}
const CTA_IMG = imageUrl(whyFaPage?.ctaImage, 2400, 1400);
const CTA_PARALLAX = Boolean(whyFaPage?.ctaParallax);

const comparison = [
  { label: 'Your brand', them: 'Replaced or co-branded', us: 'YOURS, UNCHANGED' },
  { label: 'Your clients', them: 'Theirs at exit', us: 'ALWAYS YOURS' },
  { label: 'Your equity', them: 'Sold for cash + earnout', us: 'YOU STAY THE OWNER' },
  { label: 'Exit pressure', them: 'Built to flip in 5–7 yrs', us: 'LONG-TERM HOLD' },
  { label: 'Investment freedom', them: 'Mandated models', us: 'YOU CHOOSE' },
  { label: 'Ownership', them: 'PE-backed', us: 'ADVISOR-OWNED' },
];

const outcomes = [
  { num: '01', title: 'RATIONAL COMPLIANCE THAT WORKS FOR YOU.' },
  { num: '02', title: 'FLEXIBILITY IN TECHNOLOGY.' },
  { num: '03', title: 'AI-DRIVEN TOOLS AND SUPPORT.' },
  { num: '04', title: 'OWN YOUR BOOK AND BUILD YOUR OWN EQUITY.' },
  { num: '05', title: 'A PEER NETWORK — YOU’RE NOT ALONE.' },
  { num: '06', title: 'SUCCESSION OPTIONALITY, GROWTH TAILWIND, AND MARKETING SUPPORT.' },
];

type ServiceItem = { name: string; desc: string };
type ServiceTab = {
  id: string;
  title: string;
  summary: string;
  graphic: string; // full inline SVG shown on desktop/tablet (hidden ≤900px)
  items: ServiceItem[];
};

// Original per-tab icons: 24x24, currentColor stroke (brand green via .tab-icon).
const svgWrap = (inner: string) =>
  `<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${inner}</svg>`;
const graphics = {
  technology: svgWrap('<rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>'),
  operations: svgWrap('<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>'),
  investments: svgWrap('<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="3" y1="20" x2="21" y2="20"/>'),
  compliance: svgWrap('<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>'),
  growthCoaching: svgWrap('<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>'),
};

const serviceTabs: ServiceTab[] = [
  {
    id: 'technology',
    title: 'Technology',
    summary: 'Institutional-grade tools — configured, supported, and ready to go on day one.',
    graphic: graphics.technology,
    items: [
      { name: 'Black Diamond Performance / Account Reporting', desc: 'Institutional-grade portfolio reporting and performance analytics that elevate your client presentations and streamline account management.' },
      { name: 'By All Account Aggregation', desc: 'Comprehensive account aggregation across all client assets, providing a complete financial picture for better planning and advisory services.' },
      { name: 'Salentica Salesforce CRM', desc: 'Purpose-built wealth management CRM that helps you systematize client relationships, track opportunities, and scale your practice efficiently.' },
      { name: 'Egnyte Cloud Client File System', desc: 'Secure, compliant cloud storage that enables seamless document management and team collaboration from anywhere.' },
      { name: 'Office 365 Suite and Email', desc: 'Enterprise-level productivity tools including email, Teams, and the complete Microsoft Office suite for professional client communications.' },
      { name: 'Preferred Pricing on Fintech Software', desc: 'Access to negotiated pricing on leading financial technology platforms, reducing your overhead and improving profit margins.' },
      { name: 'Ongoing Training and Support', desc: 'Continuous education and technical support ensuring you maximize the value of every technology platform we provide.' },
    ],
  },
  {
    id: 'operations',
    title: 'Operations',
    summary: 'We handle the back office so you can focus on clients — not paperwork.',
    graphic: graphics.operations,
    items: [
      { name: 'Quarterly Fees & Billing', desc: 'Quarterly fee calculation, billing, and collection processes that eliminate administrative burden and ensure consistent cash flow.' },
      { name: 'Initial Training for Support Staff', desc: 'Comprehensive onboarding and training for your team on FA systems and custodial platforms.' },
      { name: 'Digital Account Opening & Workflow Automation', desc: 'Streamlined Docusign account opening paired with seamless platform integrations and automated workflows that eliminate paperwork, redundant data entry, and processing delays.' },
      { name: 'Multiple Custodial Access', desc: 'Pre-established relationships with multiple custodians giving you flexibility in serving clients and negotiating better terms.' },
      { name: 'Operations Backup', desc: 'Experienced operations team ready to support your practice during staff transitions, vacations, or unexpected absences.' },
      { name: 'Transition Support', desc: 'White-glove onboarding assistance that handles the heavy lifting of moving your practice, minimizing disruption to your business.' },
      { name: 'Alternative Investments Access (RIA)', desc: 'Access to institutional alternative investment platforms and due diligence, expanding your ability to serve sophisticated clients.' },
    ],
  },
  {
    id: 'investments',
    title: 'Investments',
    summary: 'An optional turnkey investment platform — CIO-led and fully supported — to help you grow your clients’ wealth.',
    graphic: graphics.investments,
    items: [
      { name: 'Turnkey Investment Platform', desc: 'A fully-managed investment platform with models, execution, and reporting that lets advisors plug in without building an in-house investment operation.' },
      { name: 'CIO Services', desc: 'Chief Investment Officer-led strategy, market commentary, and portfolio construction that give you the intellectual capital of an institutional shop on demand.' },
      { name: 'White-Labeled Collateral & Commentary', desc: 'Client-ready market updates, investment briefs, and portfolio commentary delivered under your firm’s brand, not ours.' },
      { name: 'Active & Passive Strategies', desc: 'Access to a full spectrum of investment approaches, from low-cost index portfolios to actively managed strategies, giving you the flexibility to match each client’s mandate.' },
      { name: 'Team of CFAs & CMTs', desc: 'Dedicated investment professionals with CFA and CMT credentials driving research, security selection, and technical analysis.' },
      { name: 'Full Trading & Operational Support', desc: 'End-to-end trade execution, rebalancing, and portfolio operations that let you spend your time with clients instead of at the trade desk.' },
    ],
  },
  {
    id: 'compliance',
    title: 'Compliance',
    summary: 'Full regulatory oversight — so you can focus on what you do best and never lose sleep over an audit.',
    graphic: graphics.compliance,
    items: [
      { name: 'Compliance Oversight & CCO Support', desc: 'Comprehensive regulatory supervision with direct access to an experienced Chief Compliance Officer, powered by industry-leading compliance software that automates workflows, document management, and regulatory reporting.' },
      { name: 'SEC & FINRA Registrations, ADV Filings', desc: 'Expert handling of all regulatory registrations, ongoing filings, and Form ADV updates and amendments.' },
      { name: 'Audits & Regulatory Exams', desc: 'Professional preparation and representation during regulatory examinations, minimizing disruption and ensuring favorable outcomes.' },
      { name: 'Policy, Procedures & Code of Ethics Manuals', desc: 'Regularly updated compliance and ethics manuals tailored to wealth management practices, with clear personal trading policies that protect your clients and your reputation.' },
      { name: 'Email & Social Media Archiving & Review', desc: 'Automated capture and monitoring of all electronic communications ensuring compliance with FINRA and SEC record-keeping requirements.' },
      { name: 'E&O Insurance', desc: 'Group errors and omissions coverage providing comprehensive liability protection at preferred rates.' },
      { name: 'Annual Attestations & Account Reviews', desc: 'Systematic management of required annual certifications alongside regular review of client account activity to identify and address potential compliance issues proactively.' },
    ],
  },
  {
    id: 'growth-coaching',
    title: 'Growth Coaching',
    summary: 'A proven system designed to drive 20–30% annual growth — with the coaching, tools, and network to back it up.',
    graphic: graphics.growthCoaching,
    items: [
      { name: '5 Pillar Growth Plan', desc: 'Proven framework that systematically drives 20–30% annual growth through strategic client acquisition and relationship development.' },
      { name: 'Book of Business Segmentation and Optimization', desc: 'Data-driven analysis to identify your best clients, optimize service models, and increase profitability per relationship.' },
      { name: 'Client Advocacy & COI Referral Strategy', desc: 'Structured programs that transform satisfied clients into active advocates alongside a systematic approach to building and leveraging Centers of Influence — creating predictable, referral-based growth.' },
      { name: 'Next-Gen Outreach & Workshop System', desc: 'Modern marketing and engagement approaches to attract next-generation high-net-worth clients, paired with turnkey educational events and seminars that position you as the local expert and generate qualified prospects.' },
      { name: '1v1 Planning & Coaching Sessions', desc: 'Regular personalized coaching with experienced advisors who have successfully scaled their practices.' },
      { name: 'Access to the FA Advisory Network', desc: 'Collaborative community of growth-focused advisors sharing best practices, strategies, and support.' },
      { name: 'Talent Strategy', desc: 'Recruiting and staffing processes to help you acquire and maintain the best team.' },
    ],
  },
