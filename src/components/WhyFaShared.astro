---

<section class="surface-elev">
  <div class="container">
    <div class="section-head">
      <p class="eyebrow">The difference</p>
      <h2>AN ALLIANCE — NOT AN AGGREGATOR.</h2>
    </div>
    <table class="ctable">
      <thead>
        <tr>
          <th></th>
          <th>Typical aggregator</th>
          <th class="col-us-head">Fiduciary Alliance</th>
        </tr>
      </thead>
      <tbody>
        {comparison.map(row => (
          <tr>
            <td class="row-label">{row.label}</td>
            <td class="col-them">{row.them}</td>
            <td class="col-us">{row.us}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<section>
  <div class="container">
    <div class="section-head">
      <p class="eyebrow">The FA difference</p>
      <h2>WHAT CHANGES WHEN YOU JOIN.</h2>
    </div>
    <div class="outcomes">
      {outcomes.map(o => (
        <div class="outcome">
          <div class="num">{o.num}</div>
          <h3>{o.title}</h3>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="services-section">
  <div class="container">
    <div class="section-head">
      <p class="eyebrow">The platform</p>
      <h2>WHAT WE PROVIDE.</h2>
    </div>
    <div class="services-tabs">
      <div class="tabs-nav" role="tablist" aria-label="Service categories">
        {serviceTabs.map((tab, i) => (
          <button
            type="button"
            role="tab"
            class="tab"
            id={`tab-${tab.id}`}
            aria-controls={`panel-${tab.id}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            tabindex={i === 0 ? 0 : -1}
          >{tab.title}</button>
        ))}
      </div>
      {serviceTabs.map((tab, i) => (
        <div
          class="tab-panel"
          role="tabpanel"
          id={`panel-${tab.id}`}
          aria-labelledby={`tab-${tab.id}`}
          hidden={i !== 0}
        >
          <div class="tab-panel-grid">
            <div class="tab-panel-left">
              <h3 class="tab-headline">{tab.title}</h3>
              <p class="tab-summary">{tab.summary}</p>
              <div class="tab-graphic" aria-hidden="true" set:html={tab.graphic}></div>
            </div>
            <ul class="tab-items">
              {tab.items.map(item => (
                <li class="tab-item">
                  <details class="tab-item-details">
                    <summary>
                      <span class="tab-item-icon" aria-hidden="true">
                        <svg viewBox="0 0 20 20" width="14" height="14">
                          <path d="M5 10l3.5 3.5L15 7" stroke="currentColor" stroke-width="2.2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      </span>
                      <span class="tab-item-name">{item.name}</span>
                      <span class="tab-item-chevron" aria-hidden="true">
                        <svg viewBox="0 0 20 20" width="16" height="16">
                          <path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      </span>
                    </summary>
                    <p class="tab-item-desc">{item.desc}</p>
                  </details>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<section id="how-a-partnership-works">
  <div class="container">
    <div class="section-head">
      <p class="eyebrow">How a partnership works</p>
      <h2>FROM FIRST CONVERSATION TO LAUNCH.</h2>
      <p style="margin-top:1.25rem;max-width:60ch;">A step-by-step walkthrough of the partnership process — onboarding, transition support, and what your first 90 days look like inside the alliance. Detailed timeline coming soon.</p>
    </div>
  </div>
</section>

<section class="cta-strip">
  <div class="container">
    <div class="cta-row">
      <h2>READY TO SEE IF YOU&rsquo;RE A FIT?</h2>
      <div class="actions">
        <a class="btn btn-primary" href={settings.calendlyUrl} target="_blank" rel="noopener">See If You&rsquo;re a Fit <span class="arrow">→</span></a>
      </div>
    </div>
  </div>
</section>

<script>
  function setupServiceTabs() {
    document.querySelectorAll<HTMLElement>('.services-tabs').forEach(group => {
      if (group.dataset.ready === '1') return;
      group.dataset.ready = '1';
      const tabs = Array.from(group.querySelectorAll<HTMLButtonElement>('[role="tab"]'));
      const panels = Array.from(group.querySelectorAll<HTMLElement>('[role="tabpanel"]'));
      const activate = (idx: number) => {
        tabs.forEach((t, i) => {
          const on = i === idx;
          t.setAttribute('aria-selected', on ? 'true' : 'false');
          t.setAttribute('tabindex', on ? '0' : '-1');
          panels[i].hidden = !on;
        });
      };
      tabs.forEach((tab, idx) => {
        tab.addEventListener('click', () => activate(idx));
        tab.addEventListener('keydown', (e) => {
          const len = tabs.length;
          if (e.key === 'ArrowRight') { e.preventDefault(); const n = (idx + 1) % len; activate(n); tabs[n].focus(); }
          else if (e.key === 'ArrowLeft') { e.preventDefault(); const n = (idx - 1 + len) % len; activate(n); tabs[n].focus(); }
          else if (e.key === 'Home') { e.preventDefault(); activate(0); tabs[0].focus(); }
          else if (e.key === 'End') { e.preventDefault(); activate(len - 1); tabs[len - 1].focus(); }
        });
      });
    });
  }
  setupServiceTabs();
  document.addEventListener('astro:page-load', setupServiceTabs);
</script>
