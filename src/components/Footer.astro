---
import Logo from './Logo.astro';
import { url } from '../utils/url';
import { getSiteSettings, phoneToTel } from '../lib/sanity';
const settings = await getSiteSettings();
const year = 2026;
---
<footer class="site">
  <div class="container">
    <div class="row">
      <div>
        <Logo />
        <p style="margin-top:1.25rem;color:#8A98AE;max-width:32ch;font-size:0.9375rem;">An advisor-owned network of independent RIAs. Greenville, SC.</p>
        <div class="footer-social">
          <a href="https://www.linkedin.com/company/fiduciary-alliance/" target="_blank" rel="noopener" aria-label="Fiduciary Alliance on LinkedIn">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a href="https://youtube.com/@fiduciaryalliance?si=CUbM4zzRwUMJln_F" target="_blank" rel="noopener" aria-label="Fiduciary Alliance on YouTube">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.42a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.42 8.6.42 8.6.42s6.88 0 8.6-.42a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/></svg>
          </a>
        </div>
      </div>
      <div>
        <h5>Explore</h5>
        <a href={url('/why-fa/breakaway')}>Breakaway</a>
        <a href={url('/why-fa/ria-owners')}>RIA Owners</a>
        <a href={url('/firms')}>Member Firms</a>
        <a href={url('/team')}>Our Team</a>
        <a href={url('/insights')}>Insights</a>
        <a href={url('/summit')}>Advisor Summit</a>
        <a href={url('/assessment')}>Health Assessment</a>
      </div>
      <div>
        <h5>Get in touch</h5>
        <a href={settings.calendlyUrl} target="_blank" rel="noopener">See If You&rsquo;re a Fit</a>
        <a href={`tel:${phoneToTel(settings.phone)}`}>{settings.phone}</a>
      </div>
      <div>
        <h5><a href={url('/disclosures')} class="footer-section-link">Compliance</a></h5>
      </div>
    </div>
    <div class="mini">
      <span>© {year} Fiduciary Alliance, LLC</span>
      <span>{settings.address}</span>
    </div>
  </div>
</footer>
